# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Public base URL of the web app (used by auth + Telegram webhook)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (PostgreSQL on Beget) ───────────────────────────────────────────
# Local dev: localhost. In Docker Compose use host "postgres" (the service name).
DATABASE_URL=postgresql://julow:julow@localhost:5432/julow?schema=public
# Optional: direct (non-pooled) connection for migrations
DIRECT_DATABASE_URL=postgresql://julow:julow@localhost:5432/julow?schema=public
# Optional: shadow DB for `prisma migrate dev`
SHADOW_DATABASE_URL=

# Postgres container credentials (used by docker-compose)
POSTGRES_USER=julow
POSTGRES_PASSWORD=julow
POSTGRES_DB=julow

# ─── Deployment (Caddy / domains) ─────────────────────────────────────────────
APP_DOMAIN=julow.example.com
WS_DOMAIN=ws.julow.example.com

# ─── Auth (better-auth) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# ─── Redis (queues + pub/sub) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Vercel AI Gateway (LLM provider) ─────────────────────────────────────────
AI_GATEWAY_API_KEY=vck_...
# Budget defaults — cheap model for routine work, stronger model on demand
AI_GATEWAY_DEFAULT_MODEL=openai/gpt-4o-mini
AI_GATEWAY_STRONG_MODEL=anthropic/claude-3.5-sonnet
# Cheap multimodal model for optional server transcription (off by default)
AI_GATEWAY_TRANSCRIBE_MODEL=google/gemini-2.5-flash
# Set true only if you need paid server STT; web/mobile use free on-device speech
VOICE_SERVER_TRANSCRIBE=false
# Cheap model that summarizes web-research results (defaults to DEFAULT_MODEL)
AI_GATEWAY_RESEARCH_MODEL=openai/gpt-4o-mini
# Cheap model that drafts document/report content (defaults to DEFAULT_MODEL)
AI_GATEWAY_DOC_MODEL=openai/gpt-4o-mini
# Max web-search results pulled per research call (keeps token cost low)
RESEARCH_MAX_RESULTS=5
# Hard monthly spend cap (USD) per workspace, enforced in app
AGENT_MONTHLY_BUDGET_USD=25

# ─── S3 (Beget object storage, S3-compatible) ─────────────────────────────────
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_REGION=ru-1
S3_BUCKET=julow
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Use path-style addressing for most S3-compatible providers
S3_FORCE_PATH_STYLE=true

# ─── Realtime (Hocuspocus / Yjs) ──────────────────────────────────────────────
WS_PORT=1234
NEXT_PUBLIC_WS_URL=ws://localhost:1234

# ─── Email (SMTP — Beget-compatible) ─────────────────────────────────────────
# Leave SMTP_HOST empty in dev to log rendered emails to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Julow <noreply@yourdomain.com>"
SMTP_SECURE=false

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Secret path token for the webhook endpoint
TELEGRAM_WEBHOOK_SECRET=change-me
